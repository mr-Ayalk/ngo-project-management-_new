generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String          @id @default(cuid())
  email            String          @unique
  name             String
  password         String
  avatar           String?
  role             String          @default("staff")
  staffRole        String?
  isActive         Boolean         @default(true)
  lastLogin        DateTime?
  joinedDate       DateTime        @default(now())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  activities       Activity[]
  auditLogs        AuditLog[]
  messages         Message[]       @relation("MessageSender")
  notifications    Notification[]
  payments         Payment[]       @relation("PaymentUser")
  projects         Project[]       @relation("ProjectManager")
  ledProjects      Project[]       @relation("ProjectLead")
  tasks            Task[]          @relation("TaskAssignee")
  projectMembers   ProjectMember[]
  pinnedProjects   PinnedProject[]
  taskComments     TaskComment[]   @relation("CommentSender")
}

model Organization {
  id                     String   @id @default(cuid())
  name                   String
  email                  String?
  phone                  String?
  country                String?
  location               String?
  description            String?
  dateFormat             String   @default("DD/MM/YYYY")
  timezone               String   @default("Africa/Addis_Ababa")
  fiscalYearStart        String   @default("July")
  totalBeneficiaries     Int      @default(0)
  childrenCount          Int      @default(0)
  womenFamiliesCount     Int      @default(0)
  communityMembersCount  Int      @default(0)
  beneficiariesThisMonth Int      @default(0)
  activePrograms         Int      @default(0)
  completionRate         Int      @default(0)
  updatedAt              DateTime @updatedAt
}

model Project {
  id                   String               @id @default(cuid())
  name                 String
  description          String?
  status               String               @default("on-track")
  icon                 String               @default("green")
  startDate            DateTime
  endDate              DateTime
  budget               Float
  spent                Float                @default(0)
  progress             Int                  @default(0)
  location             String?
  donor                String?
  donorName            String?
  assumptions          String?              @db.Text
  risks                String?              @db.Text
  indicators           String?              @db.Text
  outcomes             String?              @db.Text
  income               Float                @default(0)
  locationType         String?
  region               String?
  zone                 String?
  town                 String?
  kebele               String?
  woreda               String?
  woredaBudget         Float?
  mitigationStrategies String?              @db.Text
  managerId            String
  leadId               String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  activities           Activity[]
  beneficiaries        BeneficiaryProject[]
  budgets              Budget[]
  calendarEvents       CalendarEvent[]
  documents            Document[]
  manager              User                 @relation("ProjectManager", fields: [managerId], references: [id])
  lead                 User?                @relation("ProjectLead", fields: [leadId], references: [id])
  members              ProjectMember[]
  pinnedBy             PinnedProject[]
  comments             TaskComment[]
  tasks                Task[]
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String   @default("member")
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model PinnedProject {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

model Task {
  id          String        @id @default(cuid())
  title       String
  description String?
  status      String        @default("todo")
  priority    String        @default("medium")
  dueDate     DateTime?
  projectId   String
  assigneeId  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  activities  Activity[]
  comments    TaskComment[]
  assignee    User?         @relation("TaskAssignee", fields: [assigneeId], references: [id])
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model TaskComment {
  id        String   @id @default(cuid())
  content   String
  taskId    String
  projectId String
  senderId  String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sender    User     @relation("CommentSender", fields: [senderId], references: [id])
}

model Beneficiary {
  id           String               @id @default(cuid())
  name         String
  email        String?
  phone        String?
  program      String?
  category     String?
  status       String               @default("active")
  enrolledDate DateTime             @default(now())
  region       String?
  notes        String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  projects     BeneficiaryProject[]
}

model BeneficiaryProject {
  id            String      @id @default(cuid())
  beneficiaryId String
  projectId     String
  enrolledDate  DateTime    @default(now())
  beneficiary   Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([beneficiaryId, projectId])
}

model Budget {
  id        String   @id @default(cuid())
  projectId String
  category  String
  allocated Float
  spent     Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Document {
  id         String   @id @default(cuid())
  projectId  String?
  name       String
  url        String   @default("#")
  fileType   String?
  category   String?
  size       String?
  icon       String?
  uploadedAt DateTime @default(now())
  project    Project? @relation(fields: [projectId], references: [id])
}

model Partner {
  id          String   @id @default(cuid())
  name        String
  type        String
  description String?
  contact     String?
  email       String?
  phone       String?
  since       Int?
  amount      Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Report {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  reportDate  DateTime
  fileUrl     String?
  fileName    String?
  fileType    String?
  fileSize    String?
  createdAt   DateTime @default(now())
}

model CalendarEvent {
  id        String   @id @default(cuid())
  title     String
  date      DateTime
  time      String?
  allDay    Boolean  @default(false)
  color     String   @default("green")
  projectId String?
  createdAt DateTime @default(now())
  project   Project? @relation(fields: [projectId], references: [id])
}

model Message {
  id          String   @id @default(cuid())
  content     String
  encrypted   String?
  senderId    String
  recipientId String?
  groupId     String?
  projectId   String?
  taskId      String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  sender      User     @relation("MessageSender", fields: [senderId], references: [id])
}

model Activity {
  id          String   @id @default(cuid())
  action      String
  entity      String
  entityId    String
  description String?
  userId      String
  projectId   String?
  taskId      String?
  createdAt   DateTime @default(now())
  project     Project? @relation(fields: [projectId], references: [id])
  task        Task?    @relation(fields: [taskId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String?
  projectId String?
  taskId    String?
  linkType  String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id            String   @id @default(cuid())
  userId        String
  amount        Float
  currency      String   @default("ETB")
  method        String
  status        String   @default("pending")
  transactionId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation("PaymentUser", fields: [userId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  resource  String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model LogisticsShipment {
  id            String    @id @default(cuid())
  reference     String
  description   String?
  origin        String?
  destination   String
  carrier       String?
  status        String    @default("pending")
  priority      String    @default("normal")
  items         String?
  quantity      Int       @default(1)
  expectedDate  DateTime?
  deliveredDate DateTime?
  notes         String?   @db.Text
  projectId     String?
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
